---
import Layout from "../layouts/Layout.astro";
import SocialPill from "../components/SocialPill.astro";
import LinkedInIcon from "../components/icons/LinkedIn.astro";
import DownloadIcon from "../components/icons/Download.astro";
import EmailIcon from "@src/components/icons/Email.astro";
import Codigo from "../components/icons/Codigo.astro";
import TimeLine from "@src/components/cv/TimeLine.astro";
import ProjectsList from "@src/components/ProjectsList.astro";
import { projects } from "@src/projects/project";
const lastProjects = projects.slice(0, 6);
---

<Layout
  title="Omar Solís | Desarrollador Web Frontend en Mérida"
  description="Portafolio de Omar Solís, desarrollador web frontend en Mérida, Yucatán. Proyectos, CV y contacto."
  keywords="portfolio, desarrollo web, frontend, Mérida, Yucatán, Omar Solís"
>
  <section>
    <div
      class="w-full flex flex-col gap-5 md:flex-row md:items-center md:gap-16 mb-10"
    >
      <div class="leading-9">
        <h1 class="text-center md:text-left text-4xl font-bold mb-4">
          Hola 👋, Soy Omar!
        </h1>
        <div>
          <nav class="flex gap-2 my-5 text-base flex-col md:flex-row">
            <SocialPill href="https://www.linkedin.com/in/omar-fernando-solis/">
              <LinkedInIcon class="size-6" />
              LinkedIn
            </SocialPill>
            <SocialPill
              href="CV_OmarSolisCarvajal.pdf"
              download="CV_OmarSolisCarvajal.pdf"
            >
              <DownloadIcon class="size-6" />
              CV
            </SocialPill>
            <SocialPill href="mailto:omarsolisdev@gmail.com">
              <EmailIcon class="size-6" />
              omarsolisdev@gmail.com
            </SocialPill>
          </nav>
        </div>
        <div>
          <div class="text-lg space-y-2">
            <p>
              +3 años de experiencia. <span
                class="text-blue-400 dark:text-orange-200"
                >Desarrollador Web</span
              > de Mérida, Yucatán 🇲🇽. Me encanta compartir mi conocimiento en mis
              canales de
              <a
                class="text-blue-500 dark:text-orange-500 hover:underline transition"
                href="https://www.tiktok.com/@omar_solis_dev"
                target="_blank">Tiktok</a
              > y
              <a
                class="text-orange-500 dark:text-blue-500 hover:underline transition"
                href="https://www.youtube.com/@AmantesDelCodigo"
                target="_blank">Youtube</a
              > llamados <span class="font-semibold">Amantes del Código.</span>
            </p>
          </div>
        </div>
      </div>
      <div class="flex justify-center">
        <img
          src="/omarLogo.jpeg"
          alt="Omar Solis"
          loading="eager"
          class="rounded-3xl rotate-3 mx-4 md:mx-0"
          width="300"
          height="300"
          decoding="async"
        />
      </div>
    </div>
    <section>
      <h2 class="text-4xl font-bold mb-6">Mi Formación</h2>
      <TimeLine />
    </section>
    <main>
      <div
        class="flex flex-col items-start gap-0 md:justify-between md:flex-row md:items-center md:gap-2 mb-10"
      >
        <div class="text-lg font-bold flex items-center gap-2 md:mb-2">
          <h2 class="text-4xl">Mis Proyectos Recientes</h2>
        </div>
        <a
          href="/proyectos/"
          class="text-base text-center inline-block py-2 underline dark:prose-invert"
          >Todos los proyectos »
        </a>
      </div>
      <ProjectsList proyectos={lastProjects} />
    </main>

    <section data-aos="fade-up" data-aos-duration="1000">
      <h2 class="text-4xl font-bold">Contáctame</h2>
      <p>¿Tienes un proyecto en mente? ¡Hablemos!</p>
      <form id="formEmail" class="w-full  mx-auto">
        <div class="flex flex-col gap-5 mt-6 w-full">
          <!-- Nombre -->
          <div class="flex flex-col gap-2">
            <label
              for="name"
              class="text-sm font-medium text-white flex items-center gap-1"
            >
              Tu nombre
              <span class="text-red-400">*</span>
            </label>

            <div class="relative group">
              <input
                type="text"
                placeholder="Ej. Omar Solís"
                name="name"
                id="name"
                required
                class="peer border border-white/20 bg-white/5 backdrop-blur-md rounded-xl px-4 py-3 outline-none transition-all duration-300 focus:border-red-400 focus:ring-4 focus:ring-red-400/20 w-full text-white placeholder:text-white/50 hover:border-white/40"
              />

              <span
                class="absolute left-0 -bottom-5 text-xs text-red-400 opacity-0 peer-invalid:opacity-100 peer-placeholder-shown:opacity-0 transition"
              >
                Este campo es obligatorio
              </span>
            </div>
          </div>

          <!-- Email -->
          <div class="flex flex-col gap-2">
            <label
              for="email"
              class="text-sm font-medium text-white flex items-center gap-1"
            >
              Tu correo electrónico
              <span class="text-red-400">*</span>
            </label>

            <div class="relative">
              <input
                type="email"
                name="email"
                id="email"
                required
                placeholder="correo@ejemplo.com"
                class="peer border border-white/20 bg-white/5 backdrop-blur-md rounded-xl px-4 py-3 outline-none transition-all duration-300 focus:border-red-400 focus:ring-4 focus:ring-red-400/20 w-full text-white placeholder:text-white/50 hover:border-white/40"
              />

              <span
                class="absolute left-0 -bottom-5 text-xs text-red-400 opacity-0 peer-invalid:opacity-100 peer-placeholder-shown:opacity-0 transition"
              >
                Ingresa un correo válido
              </span>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex flex-col gap-2">
            <label for="phone" class="text-sm font-medium text-white">
              Tu número de teléfono
            </label>

            <input
              type="tel"
              name="phone"
              id="phone"
              placeholder="+52 999 123 4567"
              class="border border-white/20 bg-white/5 backdrop-blur-md rounded-xl px-4 py-3 outline-none transition-all duration-300 focus:border-red-400 focus:ring-4 focus:ring-red-400/20 w-full text-white placeholder:text-white/50 hover:border-white/40"
            />
          </div>

          <!-- Servicios -->
          <div class="flex flex-col gap-2">
            <label
              for="services"
              class="text-sm font-medium text-white flex items-center gap-1"
            >
              Servicio de interés
              <span class="text-red-400">*</span>
            </label>

            <div class="relative">
              <select
                name="services"
                id="services"
                required
                class="peer border border-white/20 bg-[#111] rounded-xl px-4 py-3 outline-none transition-all duration-300 focus:border-red-400 focus:ring-4 focus:ring-red-400/20 w-full text-white hover:border-white/40 appearance-none"
              >
                <option value="">Selecciona un servicio</option>
                <option value="landing page">Landing Page</option>
                <option value="sitio web">Sitio web</option>
                <option value="aplicacion web"
                  >Desarrollo de Aplicaciones Web</option
                >
              </select>

              <!-- Flecha -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/60 pointer-events-none"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>

              <span
                class="absolute left-0 -bottom-5 text-xs text-red-400 opacity-0 peer-invalid:opacity-100 transition"
              >
                Selecciona una opción
              </span>
            </div>
          </div>

          <!-- Mensaje -->
          <div class="flex flex-col gap-2">
            <label
              for="message"
              class="text-sm font-medium text-white flex items-center gap-1"
            >
              Cuéntame más de tu idea
              <span class="text-red-400">*</span>
            </label>

            <div class="relative">
              <textarea
                name="message"
                id="message"
                required
                placeholder="Describe tu proyecto..."
                class="peer border border-white/20 bg-white/5 backdrop-blur-md rounded-2xl px-4 py-3 h-36 resize-none outline-none transition-all duration-300 focus:border-red-400 focus:ring-4 focus:ring-red-400/20 w-full text-white placeholder:text-white/50 hover:border-white/40"
              ></textarea>

              <span
                class="absolute left-0 -bottom-5 text-xs text-red-400 opacity-0 peer-invalid:opacity-100 peer-placeholder-shown:opacity-0 transition"
              >
                Este campo es obligatorio
              </span>
            </div>
          </div>

          <!-- Botón -->
          <button
            type="submit"
            class="mt-4 bg-white text-black font-medium rounded-xl px-6 py-3 transition-all duration-300 hover:bg-transparent hover:text-white border border-white hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-white/10"
          >
            Enviar Mensaje
          </button>
        </div>
      </form>
    </section>
  </section>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>

  <script defer>
    const form = document.getElementById("formEmail");

    form?.addEventListener("submit", sendEmail);

    function sendEmail(e) {
      e.preventDefault();
      const nameInput = document.getElementById("name");
      const emailInput = document.getElementById("email");
      const phoneInput = document.getElementById("phone");
      const servicesInput = document.getElementById("services");
      const messageInput = document.getElementById("message");

      let params = {
        name: nameInput.value,
        email: emailInput.value,
        phone: phoneInput.value,
        services: servicesInput.value,
        message: messageInput.value,
      };

      emailjs
        .send("service_w6go0rb", "template_bvkb7fl", params)
        .then(function () {
          Swal.fire({
            icon: "success",
            title: "¡Mensaje enviado!",
            text: "Gracias por contactarme, te responderé lo antes posible.",
          });
          form.reset();
        })
        .catch(function () {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: "Error al enviar el mensaje, intenta de nuevo.",
          });
        });
    }
  </script>
  <style>
    section,
    main {
      margin: auto;
      padding: 1rem;
      width: 1000px;
      max-width: calc(100%);
      font-size: 20px;
      line-height: 1.6;
    }

    @keyframes shake {
      0%,
      100% {
        transform: translateX(0);
      }
      20% {
        transform: translateX(-4px);
      }
      40% {
        transform: translateX(4px);
      }
      60% {
        transform: translateX(-4px);
      }
      80% {
        transform: translateX(4px);
      }
    }

    input:invalid:focus,
    textarea:invalid:focus,
    select:invalid:focus {
      animation: shake 0.3s ease-in-out;
    }
  </style>
</Layout>
